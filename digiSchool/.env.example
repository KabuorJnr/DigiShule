# Supabase connection for the EduOne frontend.
# Copy to .env and fill in your project's values (Settings -> API).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Only needed locally to run scripts/seed.mjs (never ship this to the browser):
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email configuration
SMTP_USER=eduone.africa@gmail.com
SMTP_PASS=your-gmail-app-password
